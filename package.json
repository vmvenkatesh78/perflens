{
  "name": "react-perflens",
  "version": "0.5.0",
  "description": "React performance toolkit — track renders, surface insights, fix bottlenecks",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./panel": {
      "import": {
        "types": "./dist/panel.d.ts",
        "default": "./dist/panel.js"
      },
      "require": {
        "types": "./dist/panel.d.cts",
        "default": "./dist/panel.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "size": "size-limit",
    "validate": "publint",
    "prepublishOnly": "npm run build && npm run validate",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@size-limit/preset-small-lib": "^11.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.3.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.0.0",
    "publint": "^0.2.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "size-limit": "^11.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "size-limit": [
    {
      "name": "core",
      "path": "dist/index.js",
      "limit": "5 KB"
    },
    {
      "name": "full",
      "path": [
        "dist/index.js",
        "dist/panel.js"
      ],
      "limit": "40 KB"
    }
  ],
  "keywords": [
    "react",
    "performance",
    "profiler",
    "devtools",
    "render",
    "optimization",
    "monitoring"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vmvenkatesh78/perflens.git"
  },
  "bugs": {
    "url": "https://github.com/vmvenkatesh78/perflens/issues"
  },
  "homepage": "https://perflens.vercel.app",
  "author": "V M Venkatesh <vmvenkatesh78@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
